generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  CLEANUP_PARTNER
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

model User {
  id           String     @id @default(cuid())
  /// Normalized lowercase trimmed email (unique).
  email        String     @unique
  phone        String?    @unique
  displayName  String?
  /// Required for local email/password accounts (enforced in application layer).
  passwordHash String?
  roles        UserRole[] @default([USER])
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions       Session[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  mediaAssets    MediaAsset[]
  locationsExact LocationExact[]

  scrapRequests       ScrapRequest[]
  marketplaceListings MarketplaceListing[]
  reservations        Reservation[]
  subscriptions       Subscription[]
  cleanupReports      CleanupReport[]
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 hex of the opaque session token (never store raw token).
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  requestId  String?
  /// Safe metadata only — never passwords, tokens, or exact secrets.
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@index([requestId])
}

model MediaAsset {
  id          String    @id @default(cuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  /// Random object key under private storage (never a filesystem path in API responses).
  objectKey   String    @unique
  contentType String
  byteSize    Int
  width       Int?
  height      Int?
  originalName String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  /// One scrap request may claim a media asset as its single required photo.
  scrapRequest ScrapRequest?
  cleanupReport CleanupReport?

  @@index([ownerId])
}

/// Privileged exact location — never expose via public DTOs.
model LocationExact {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  label       String?
  addressLine String?
  ward        String?
  district    String?
  city        String?
  country     String   @default("VN")
  latitude    Float
  longitude   Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicView LocationPublic?

  @@index([ownerId])
}

/// Coarse public location derived from exact — safe for unauthorized audiences.
model LocationPublic {
  id              String   @id @default(cuid())
  exactId         String   @unique
  exact           LocationExact @relation(fields: [exactId], references: [id], onDelete: Cascade)
  approxLatitude  Float
  approxLongitude Float
  city            String?
  district        String?
  ward            String?
  /// Optional grid cell id for map bucketing.
  gridCell        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Marketplace: scrap request → quote → listing → reservation ─────────────

enum ScrapRequestStatus {
  SUBMITTED
  QUOTED
  ACCEPTED
  REJECTED
}

enum QuoteStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  COMPLETED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

/// Published price band per material. Server-enforces every admin quote inside
/// [minPricePerKgVnd, maxPricePerKgVnd] — see the CHECK constraint in the
/// marketplace migration for the same invariant at the database boundary.
model ScrapCategory {
  id               String   @id @default(cuid())
  name             String   @unique
  minPricePerKgVnd Int
  maxPricePerKgVnd Int
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  scrapRequests ScrapRequest[]
}

/// Seller's submission for quotation. mediaAssetId is @unique: exactly one
/// photo, and a photo may back only one request ever.
model ScrapRequest {
  id                String             @id @default(cuid())
  sellerId          String
  seller            User               @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  categoryId        String
  category          ScrapCategory      @relation(fields: [categoryId], references: [id])
  estimatedWeightKg Float
  mediaAssetId      String             @unique
  media             MediaAsset         @relation(fields: [mediaAssetId], references: [id])
  note              String?
  status            ScrapRequestStatus @default(SUBMITTED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  quotes  Quote[]
  listing MarketplaceListing?

  @@index([sellerId])
  @@index([status])
}

/// SUPERSEDED marks a quote replaced by a newer one on the same request —
/// quotes are kept rather than overwritten so price history stays auditable.
model Quote {
  id             String       @id @default(cuid())
  scrapRequestId String
  scrapRequest   ScrapRequest @relation(fields: [scrapRequestId], references: [id], onDelete: Cascade)
  pricePerKgVnd  Int
  status         QuoteStatus  @default(PENDING)
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?

  listing MarketplaceListing?

  @@index([scrapRequestId, status])
}

/// Snapshot created the instant a seller accepts a quote. Stores both sides of
/// the price for accounting; only buyerPricePerKgVnd is ever serialized to a
/// buyer-facing DTO (see MarketplaceListingSchema in packages/shared).
/// mediaAssetId is a plain denormalized copy of the originating
/// ScrapRequest.mediaAssetId (no FK) — the public photo route resolves it
/// directly and listing visibility must not depend on the request's lifecycle.
model MarketplaceListing {
  id                  String        @id @default(cuid())
  quoteId             String        @unique
  quote               Quote         @relation(fields: [quoteId], references: [id])
  scrapRequestId      String        @unique
  scrapRequest        ScrapRequest  @relation(fields: [scrapRequestId], references: [id])
  sellerId            String
  seller              User          @relation(fields: [sellerId], references: [id])
  categoryName        String
  estimatedWeightKg    Float
  sellerPricePerKgVnd Int
  buyerPricePerKgVnd  Int
  status              ListingStatus @default(AVAILABLE)
  mediaAssetId        String
  createdAt           DateTime      @default(now())

  reservation Reservation?

  @@index([status])
}

/// At most one reservation per listing — enforced here by @unique and, in the
/// application layer, by a conditional status update so two concurrent
/// reserve calls resolve to exactly one success.
model Reservation {
  id        String             @id @default(cuid())
  listingId String             @unique
  listing   MarketplaceListing @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User               @relation(fields: [buyerId], references: [id])
  createdAt DateTime           @default(now())

  @@index([buyerId])
}

/// Eligibility gate for reserving a listing. Not a role — several rows per
/// user are allowed so history survives; eligibility is a query, not a flag.
model Subscription {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    SubscriptionStatus
  startsAt  DateTime
  expiresAt DateTime
  note      String?
  createdAt DateTime           @default(now())

  @@index([userId, status])
}

enum CleanupReportStatus {
  SUBMITTED
  VERIFIED
  REJECTED
}

model CleanupReport {
  id           String              @id @default(cuid())
  reporterId   String
  reporter     User                @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  description  String
  addressLine  String?
  ward         String?
  district     String?
  city         String?
  mediaAssetId String              @unique
  media        MediaAsset          @relation(fields: [mediaAssetId], references: [id])
  status       CleanupReportStatus @default(SUBMITTED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  verifiedAt   DateTime?

  @@index([reporterId])
  @@index([status])
}
