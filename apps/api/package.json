{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "description": "GreenCity NestJS API",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "tsx src/storage/local-object-storage.spec.ts && tsx src/config/paths.spec.ts && jest --config jest.unit.config.cjs --runInBand",
    "test:integration": "jest --config jest.integration.config.cjs --runInBand",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@greencity/shared": "workspace:*",
    "@nestjs/common": "^11.0.7",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.7",
    "@nestjs/platform-express": "^11.0.7",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.3.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.28",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^7.2.1",
    "jest": "^30.4.2",
    "prisma": "^6.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  }
}
