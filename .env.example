# Copy to repository-root .env and replace placeholders.
# NEVER commit real credentials. Do not put secrets in shell history when avoidable.

# Required — use your local native PostgreSQL credentials
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public

API_PORT=3001
# The browser never receives an API host. Client traffic uses same-origin /api/*,
# which apps/web/next.config.ts rewrites to this port server-side. Do not add
# NEXT_PUBLIC_API_URL back — apps/web/scripts/smoke.mjs fails the build on it.

# Deploy only: where the web server forwards /api/* to. Defaults to the local
# API above. On a split deploy (web on Vercel, API on Render) set this to the
# API's public URL, e.g. https://greencity-api.onrender.com — server-side only.
# API_PROXY_TARGET=

# Comma-separated exact HTTP(S) origins (no wildcard/path) for credentialed CORS + Origin checks
CORS_ORIGINS=http://localhost:3000

# Session cookie (HttpOnly; Secure in production)
SESSION_COOKIE_NAME=gc_session
SESSION_TTL_HOURS=336

# Login rate limit (per IP)
AUTH_LOGIN_RATE_LIMIT=10
AUTH_LOGIN_RATE_TTL_SECONDS=60

# Object storage: local filesystem for Phase 0 (S3 later)
STORAGE_DRIVER=local
# Relative paths resolve from monorepo root (same from root or apps/api cwd)
STORAGE_LOCAL_DIR=.local/storage

# Optional: overrides the db:seed demo password. Local demo works without it.
# SET THIS on any shared/deployed database — the built-in default is public.
# DEMO_PASSWORD=
# Future S3-compatible (only when STORAGE_DRIVER=s3)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=auto

# Mail: console (default) or file for Phase 0 (SMTP later)
MAIL_DRIVER=console
MAIL_FILE_DIR=.local/mail
# Future SMTP (only when MAIL_DRIVER=smtp)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- scripts/db-setup.ps1 (admin + app credentials; not the same as DATABASE_URL necessarily) ---
# $env:PGPASSWORD = '<postgres-admin-password>'
# $env:GREENCITY_DB_PASSWORD = '<app-role-password>'
# $env:GREENCITY_DB_USER = 'greencity'          # optional
# $env:GREENCITY_DB_NAME = 'greencity'          # optional
