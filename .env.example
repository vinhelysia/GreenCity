# Native local PostgreSQL (no Docker required)
DATABASE_URL=postgresql://greencity:greencity@localhost:5432/greencity?schema=public

API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Object storage: local filesystem for Phase 0 (S3 later)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=.local/storage
# Future S3-compatible (only when STORAGE_DRIVER=s3)
# S3_ENDPOINT=https://s3.example.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=greencity
# S3_REGION=auto

# Mail: console (default) or file for Phase 0 (SMTP later)
MAIL_DRIVER=console
MAIL_FILE_DIR=.local/mail
# Future SMTP (only when MAIL_DRIVER=smtp)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@greencity.local
