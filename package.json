{
  "name": "greencity",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "node ./scripts/prepare.mjs",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "prebuild": "pnpm --filter @greencity/shared build",
    "build": "pnpm -r --if-present run build",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api exec prisma migrate deploy",
    "db:migrate:dev": "pnpm --filter api exec prisma migrate dev",
    "db:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db-setup.ps1",
    "db:postgis": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db-postgis.ps1",
    "db:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/db-verify.ps1"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
